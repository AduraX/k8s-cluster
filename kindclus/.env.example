# =============================================================================
# KindClus_Run — Environment configuration
#
# Copy this file to .env and fill in your values before running the install:
#   cp .env.example .env && nano .env
#
# Variables with defaults can be left as-is for a standard setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain
# Cluster domain is derived as PREFIX.SUFFIX (e.g. k8s.lcl)
# -----------------------------------------------------------------------------
PREFIX=
SUFFIX=

# -----------------------------------------------------------------------------
# Timezone
# Used for all log timestamps and elapsed-time display.
# -----------------------------------------------------------------------------
LOCAL_TZ=

# -----------------------------------------------------------------------------
# User
# The OS user under whose home directory certs and kubeconfig are stored.
# -----------------------------------------------------------------------------
K8S_USER=


# -----------------------------------------------------------------------------
# Working directory
# Root directory for project data, certs, and backups.
# Defaults to ~/workdir if left blank.
# -----------------------------------------------------------------------------
WORK_DIR=

# -----------------------------------------------------------------------------
# SSL certificates
# Path to the directory containing your TLS certs for the local domain.
# Leave blank to use the default: $WORK_DIR/.certDir/<domain>/
# -----------------------------------------------------------------------------
CERTDIR=

# -----------------------------------------------------------------------------
# Component versions
# Pin the version of each component installed into the cluster.
# -----------------------------------------------------------------------------
KIND_NODE_IMAGE=kindest/node:v1.33.4
CERT_MANAGER_VERSION=1.19.4
METALLB_VERSION=0.15.3
TRAEFIK_VERSION=37.2.0
ARGOCD_VERSION=3.3.3
LONGHORN_VERSION=1.9.0

# # -----------------------------------------------------------------------------
# # Kind cluster — port mappings
# # Host ports exposed by the Kind control-plane node.
# # -----------------------------------------------------------------------------
# HOST_PORT_HTTP=8880
# HOST_PORT_HTTPS=8443
# HOST_PORT_EXTRA=8000

# -----------------------------------------------------------------------------
# Cilium (alternative to MetalLB + Calico)
# Used only when Cilium HostNetwork mode is selected at the install prompt.
# -----------------------------------------------------------------------------
CILIUM_LB_IP_START=10.163.168.62
CILIUM_LB_IP_END=10.163.168.65
